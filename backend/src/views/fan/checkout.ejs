    .plan-option { display: flex; align-items: flex-start; gap: 14px; padding: 20px; background: #111118; border: 2px solid #2a2a3e; border-radius: 14px; cursor: pointer; transition: all 0.2s; margin-bottom: 12px; position: relative; }
