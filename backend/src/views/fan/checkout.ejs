<script src="https://checkout.sandbox.manifestfinancial.com/checkout.js"></script>
<script>
  let buyerId = null;
  let paymentMethodReady = false;
  let selectedPlan = 'standard';
  let planPrices = { standard: 2700, pro: 4700 };
  let planLabels = { standard: 'TrueFans LOOP', pro: 'TrueFans LOOP PRO' };

  function selectPlan(plan) {
    selectedPlan = plan;
    document.querySelectorAll('.plan-option').forEach(el => el.classList.remove('selected'));
    document.getElementById('plan-' + plan).classList.add('selected');
  }

  function getPrice() {
    return planPrices[selectedPlan];
  }

  function getPriceDisplay() {
    return '$' + (getPrice() / 100).toFixed(2);
  }

  async function continueToPayment() {
    const firstName = document.getElementById('firstName').value.trim();
    const lastName = document.getElementById('lastName').value.trim();
    const email = document.getElementById('email').value.trim();
    const msgEl = document.getElementById('infoMsg');
    const btn = document.getElementById('continueBtn');

    if (!firstName || !lastName || !email) {
      msgEl.textContent = 'Please fill in all fields.';
      msgEl.style.color = '#f87171';
      return;
    }
    if (!email.includes('@') || !email.includes('.')) {
      msgEl.textContent = 'Please enter a valid email address.';
      msgEl.style.color = '#f87171';
      return;
    }

    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Setting up your account...';
    msgEl.textContent = '';

    try {
      const res = await fetch('/api/checkout/create-buyer', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ first_name: firstName, last_name: lastName, email })
      });
      const data = await res.json();

      if (!res.ok || data.error) {
        throw new Error(data.error || 'Failed to create account');
      }

      buyerId = data.buyer_id;

      // Update order summary
      const price = getPriceDisplay();
      const label = planLabels[selectedPlan];
      document.getElementById('summaryPlan').innerHTML = '<span>' + label + '</span> <span>' + price + '/mo</span>';
      document.getElementById('totalAmount').textContent = price;
      document.getElementById('payBtnText').textContent = 'Complete My Order \u2014 ' + price;

      // Show payment step
      document.getElementById('info-step').classList.add('hidden');
      document.getElementById('payment-step').classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });

      // Embed Manifest payment form
      const container = document.getElementById('payment-container');
      container.innerHTML = '';

      if (typeof MCheckout !== 'undefined') {
        MCheckout.render({
          container: container,
          embed_url: data.embed_url,
          onPaymentMethodUpdated: function() {
            paymentMethodReady = true;
            document.getElementById('payBtn').disabled = false;
            document.getElementById('payMsg').textContent = 'Card accepted! Click below to complete your order.';
            document.getElementById('payMsg').style.color = '#34d399';
          },
          onError: function(err) {
            document.getElementById('payMsg').textContent = 'Payment form error. Please try again.';
            document.getElementById('payMsg').style.color = '#f87171';
          }
        });
      } else {
        container.innerHTML = '<p style="text-align:center;color:#f87171;padding:20px;">Payment form failed to load. Please refresh the page.</p>';
      }

    } catch (e) {
      msgEl.textContent = e.message;
      msgEl.style.color = '#f87171';
      btn.disabled = false;
      btn.textContent = 'Continue to Secure Payment \u2192';
    }
  }

  async function processPayment() {
    if (!paymentMethodReady || !buyerId) return;

    const btn = document.getElementById('payBtn');
    const msgEl = document.getElementById('payMsg');

    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Processing your payment...';
    msgEl.textContent = '';

    try {
      const res = await fetch('/api/checkout/process-payment', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ buyer_id: buyerId, plan: selectedPlan, amount_in_cents: getPrice() })
      });
      const data = await res.json();

      if (!res.ok || data.error) {
        throw new Error(data.error || 'Payment failed');
      }

      // Show success step
      document.getElementById('payment-step').classList.add('hidden');
      document.getElementById('success-step').classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });

    } catch (e) {
      msgEl.textContent = e.message;
      msgEl.style.color = '#f87171';
      btn.disabled = false;
      document.getElementById('payBtnText').textContent = 'Complete My Order \u2014 ' + getPriceDisplay();
    }
  }

  function backToInfo() {
    document.getElementById('payment-step').classList.add('hidden');
    document.getElementById('info-step').classList.remove('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
</script>

</body>
</html>
