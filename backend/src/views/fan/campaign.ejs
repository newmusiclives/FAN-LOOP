<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --primary: <%= brandConfig.primary_color || '#8b5cf6' %>;
      --secondary: <%= brandConfig.secondary_color || '#ec4899' %>;
    }
    body { background: #0a0a0f; color: #e2e8f0; font-family: 'Inter', system-ui, sans-serif; }
    .hero-gradient { background: linear-gradient(135deg, var(--primary), var(--secondary)); }
    .btn-signup { background: linear-gradient(135deg, var(--primary), var(--secondary)); }
    .btn-signup:hover { opacity: 0.9; transform: translateY(-1px); }
    .glow { box-shadow: 0 0 40px rgba(139, 92, 246, 0.2); }
    input { background: #1a1a2e; border: 1px solid #2a2a3e; color: #e2e8f0; }
    input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 2px rgba(139, 92, 246, 0.2); }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">
  <div class="w-full max-w-lg">
    <!-- Campaign Card -->
    <div class="bg-[#111118] border border-[#1e1e2e] rounded-2xl overflow-hidden glow">
      <!-- Header -->
      <div class="hero-gradient p-8 text-center">
        <% if (artist) { %>
          <p class="text-white/80 text-sm font-medium mb-2"><%= artist.name %></p>
        <% } %>
        <h1 class="text-3xl font-bold text-white mb-2"><%= campaign.headline || campaign.title %></h1>
        <% if (campaign.subheadline) { %>
          <p class="text-white/80"><%= campaign.subheadline %></p>
        <% } %>
      </div>

      <div class="p-8">
        <% if (campaign.description) { %>
          <p class="text-gray-400 text-sm mb-6"><%= campaign.description %></p>
        <% } %>

        <!-- Signup Form -->
        <div id="signupForm">
          <% if (error) { %>
            <div class="bg-red-900/30 border border-red-800 text-red-300 px-4 py-3 rounded-lg mb-4 text-sm"><%= error %></div>
          <% } %>

          <div class="space-y-3 mb-4">
            <input type="text" id="fanName" placeholder="Your name (optional)" class="w-full rounded-lg px-4 py-3">
            <input type="email" id="fanEmail" placeholder="Your email address" required class="w-full rounded-lg px-4 py-3">
          </div>

          <button id="signupBtn" onclick="handleSignup()" class="btn-signup w-full py-3.5 rounded-lg font-bold text-white text-lg transition-all">
            Join & Get Your Link
          </button>

          <p class="text-xs text-gray-500 text-center mt-3">
            Free to join. No spam, ever. Unsubscribe anytime.
          </p>
        </div>

        <!-- Success (hidden initially) -->
        <div id="successView" class="hidden text-center">
          <div class="text-4xl mb-3">🎉</div>
          <h2 class="text-xl font-bold mb-2">You're In!</h2>
          <p class="text-gray-400 text-sm mb-4">Share your unique link to climb the leaderboard and unlock rewards</p>
          <a id="dashboardLink" href="#" class="btn-signup inline-block px-6 py-3 rounded-lg font-semibold text-white">Go to Your Dashboard</a>
        </div>

        <!-- Reward Tiers Preview -->
        <% if (rewardTiers.length > 0) { %>
          <div class="mt-8 pt-6 border-t border-[#1e1e2e]">
            <h3 class="text-sm font-semibold text-gray-400 mb-3">REWARD TIERS</h3>
            <div class="space-y-2">
              <% rewardTiers.forEach(tier => { %>
                <div class="flex items-center justify-between p-3 rounded-lg bg-[#0a0a0f]">
                  <div>
                    <span class="text-sm font-medium"><%= tier.tier || tier.name %></span>
                    <span class="text-xs text-gray-500 ml-2"><%= tier.reward %></span>
                  </div>
                  <span class="text-xs font-semibold" style="color: var(--primary)"><%= tier.referrals %> refs</span>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>
      </div>
    </div>

    <p class="text-center text-xs text-gray-600 mt-4">Powered by <span class="text-purple-400">FANLOOP</span></p>
  </div>

  <script>
    // Device fingerprint (simple)
    function getFingerprint() {
      const canvas = document.createElement('canvas');
      const ctx = canvas.getContext('2d');
      ctx.textBaseline = 'top';
      ctx.font = '14px Arial';
      ctx.fillText('fingerprint', 2, 2);
      const data = canvas.toDataURL();
      let hash = 0;
      for (let i = 0; i < data.length; i++) {
        const char = data.charCodeAt(i);
        hash = ((hash << 5) - hash) + char;
        hash = hash & hash;
      }
      return Math.abs(hash).toString(36) + navigator.language + screen.width;
    }

    async function handleSignup() {
      const btn = document.getElementById('signupBtn');
      const email = document.getElementById('fanEmail').value;
      if (!email || !email.includes('@')) {
        alert('Please enter a valid email');
        return;
      }

      btn.textContent = 'Joining...';
      btn.disabled = true;

      try {
        const res = await fetch('/c/<%= campaign.slug %>/signup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            name: document.getElementById('fanName').value,
            ref: '<%= referralCode || '' %>',
            device_fingerprint: getFingerprint()
          })
        });

        const data = await res.json();
        if (data.success) {
          document.getElementById('signupForm').classList.add('hidden');
          document.getElementById('successView').classList.remove('hidden');
          document.getElementById('dashboardLink').href = data.dashboard_url;
        } else {
          alert(data.error || 'Something went wrong');
          btn.textContent = 'Join & Get Your Link';
          btn.disabled = false;
        }
      } catch (e) {
        alert('Network error. Please try again.');
        btn.textContent = 'Join & Get Your Link';
        btn.disabled = false;
      }
    }

    // Enter key submits
    document.getElementById('fanEmail').addEventListener('keypress', (e) => {
      if (e.key === 'Enter') handleSignup();
    });
  </script>
</body>
</html>
