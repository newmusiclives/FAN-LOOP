<%- include('../partials/admin-layout') %>

<div class="mb-8">
  <h2 class="text-2xl font-bold">Settings</h2>
</div>

<div class="max-w-2xl space-y-6">
  <!-- Password -->
  <div class="card p-6">
    <h3 class="text-lg font-semibold mb-4">Change Password</h3>
    <form method="POST" action="/admin/settings/password" class="space-y-3">
      <input type="password" name="current_password" placeholder="Current password" required class="w-full">
      <input type="password" name="new_password" placeholder="New password" required minlength="6" class="w-full">
      <button class="btn-primary px-5 py-2 rounded-lg text-white text-sm">Update Password</button>
    </form>
  </div>

  <!-- Integrations -->
  <div class="card p-6">
    <h3 class="text-lg font-semibold mb-4">Integrations</h3>

    <div class="space-y-3 mb-6">
      <% integrations.forEach(int => { %>
        <div class="flex items-center justify-between p-3 rounded-lg bg-[#1a1a2e]">
          <div>
            <div class="text-sm font-medium"><%= int.name %></div>
            <div class="text-xs text-gray-500"><%= int.type %> — <%= int.active ? 'Active' : 'Inactive' %></div>
          </div>
          <form method="POST" action="/admin/settings/integrations/<%= int.id %>/delete">
            <button class="text-xs text-red-400 hover:text-red-300">Remove</button>
          </form>
        </div>
      <% }) %>
    </div>

    <form method="POST" action="/admin/settings/integrations" class="p-4 rounded-lg border border-dashed border-[#2a2a3e]">
      <h4 class="text-sm font-medium mb-3">Add Integration</h4>
      <div class="grid grid-cols-2 gap-3 mb-3">
        <div>
          <label class="text-xs text-gray-500">Artist</label>
          <select name="artist_id" required class="w-full text-sm">
            <% artists.forEach(a => { %>
              <option value="<%= a.id %>"><%= a.name %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="text-xs text-gray-500">Type</label>
          <select name="type" required class="w-full text-sm">
            <option value="webhook">Webhook (Zapier)</option>
            <option value="mailchimp">Mailchimp</option>
            <option value="convertkit">ConvertKit</option>
          </select>
        </div>
      </div>
      <input name="name" placeholder="Integration name" required class="w-full text-sm mb-3">
      <input name="webhook_url" placeholder="Webhook URL" class="w-full text-sm mb-3">
      <input name="api_key" placeholder="API Key (optional)" class="w-full text-sm mb-3">
      <button class="btn-primary px-4 py-1.5 rounded-lg text-white text-sm">Add Integration</button>
    </form>
  </div>
</div>

<%- include('../partials/admin-footer') %>
