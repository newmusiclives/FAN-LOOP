<%- include('../partials/admin-layout') %>

<div class="mb-8">
  <h2 class="text-2xl font-bold">Reward Fulfillment</h2>
  <p class="text-gray-500 mt-1"><%= claims.length %> pending claims</p>
</div>

<div class="card overflow-hidden">
  <table>
    <thead>
      <tr class="text-left">
        <th class="px-6 py-3">Fan</th>
        <th class="px-6 py-3">Campaign</th>
        <th class="px-6 py-3">Reward</th>
        <th class="px-6 py-3">Claimed</th>
        <th class="px-6 py-3">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% claims.forEach(claim => { %>
        <tr class="hover:bg-[#1a1a2e]">
          <td class="px-6 py-4">
            <div class="text-sm font-medium"><%= claim.fan_name || claim.fan_email %></div>
            <div class="text-xs text-gray-500"><%= claim.fan_email %></div>
          </td>
          <td class="px-6 py-4 text-sm"><%= claim.campaign_title %></td>
          <td class="px-6 py-4">
            <div class="text-sm font-medium"><%= claim.tier_name %></div>
            <div class="text-xs text-gray-500"><%= claim.reward_description %></div>
          </td>
          <td class="px-6 py-4 text-xs text-gray-500"><%= new Date(claim.claimed_at).toLocaleDateString() %></td>
          <td class="px-6 py-4">
            <div class="flex gap-2">
              <form method="POST" action="/admin/rewards/<%= claim.id %>/approve">
                <button class="px-3 py-1 rounded text-xs bg-green-700 text-green-200 hover:bg-green-600">Approve</button>
              </form>
              <form method="POST" action="/admin/rewards/<%= claim.id %>/deny">
                <button class="px-3 py-1 rounded text-xs bg-red-900 text-red-300 hover:bg-red-800">Deny</button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
      <% if (claims.length === 0) { %>
        <tr><td colspan="5" class="px-6 py-12 text-center text-gray-500">No pending reward claims</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('../partials/admin-footer') %>
