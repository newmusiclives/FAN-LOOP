<%- include('../partials/admin-layout') %>

<div class="flex items-center justify-between mb-8">
  <div>
    <a href="/admin/campaigns" class="text-sm text-gray-500 hover:text-gray-300">&larr; Back to Campaigns</a>
    <h2 class="text-2xl font-bold mt-2"><%= campaign.title %></h2>
    <div class="flex items-center gap-3 mt-1">
      <span class="badge <%= campaign.status === 'active' ? 'badge-green' : campaign.status === 'draft' ? 'badge-gray' : 'badge-yellow' %>"><%= campaign.status %></span>
      <span class="text-sm text-gray-500">/c/<%= campaign.slug %></span>
      <span class="text-sm text-gray-500">by <%= artist?.name %></span>
    </div>
  </div>
  <div class="flex gap-2">
    <a href="/c/<%= campaign.slug %>" target="_blank" class="px-4 py-2 rounded-lg text-sm border border-[#2a2a3e] hover:bg-[#1a1a2e]">View Page</a>
    <a href="/admin/campaigns/<%= campaign.id %>/edit" class="btn-primary px-4 py-2 rounded-lg text-white text-sm">Edit</a>
  </div>
</div>

<!-- Stats -->
<div class="grid grid-cols-4 gap-4 mb-6">
  <div class="stat-card rounded-xl p-4">
    <div class="text-gray-400 text-xs mb-1">Total Fans</div>
    <div class="text-2xl font-bold"><%= campaign.fan_count %></div>
  </div>
  <div class="stat-card rounded-xl p-4">
    <div class="text-gray-400 text-xs mb-1">Referrals</div>
    <div class="text-2xl font-bold text-purple-400"><%= referralCount %></div>
  </div>
  <div class="stat-card rounded-xl p-4">
    <div class="text-gray-400 text-xs mb-1">K-Factor</div>
    <div class="text-2xl font-bold text-green-400"><%= kFactor %></div>
  </div>
  <div class="stat-card rounded-xl p-4">
    <div class="text-gray-400 text-xs mb-1">Rewards</div>
    <div class="text-2xl font-bold text-pink-400"><%= rewards.length %></div>
  </div>
</div>

<!-- Status Control -->
<div class="card p-4 mb-6">
  <div class="flex items-center gap-3">
    <span class="text-sm text-gray-400">Status:</span>
    <form method="POST" action="/admin/campaigns/<%= campaign.id %>/status" class="flex gap-2">
      <% ['draft', 'active', 'paused', 'ended'].forEach(s => { %>
        <button name="status" value="<%= s %>" class="px-3 py-1 rounded text-xs <%= campaign.status === s ? 'bg-purple-600 text-white' : 'bg-[#1a1a2e] text-gray-400 hover:text-white' %>"><%= s %></button>
      <% }) %>
    </form>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Recent Fans -->
  <div class="card p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold">Recent Fans</h3>
      <a href="/admin/fans?campaign_id=<%= campaign.id %>" class="text-sm text-purple-400">View all</a>
    </div>
    <table>
      <thead><tr><th class="text-left pb-2">Fan</th><th class="text-left pb-2">Referrals</th><th class="text-left pb-2">Joined</th></tr></thead>
      <tbody>
        <% fans.forEach(fan => { %>
          <tr>
            <td class="py-2"><a href="/admin/fans/<%= fan.id %>" class="text-sm hover:text-purple-400"><%= fan.name || fan.email %></a></td>
            <td class="py-2 text-sm"><%= fan.referral_count %></td>
            <td class="py-2 text-xs text-gray-500"><%= new Date(fan.created_at).toLocaleDateString() %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Reward Tiers -->
  <div class="card p-6">
    <h3 class="text-lg font-semibold mb-4">Reward Tiers</h3>
    <div class="space-y-3 mb-6">
      <% rewards.forEach(reward => { %>
        <div class="flex items-center justify-between p-3 rounded-lg bg-[#1a1a2e]">
          <div>
            <div class="text-sm font-medium"><%= reward.tier_name %></div>
            <div class="text-xs text-gray-500"><%= reward.description %></div>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-sm text-purple-400"><%= reward.referrals_required %> refs</span>
            <form method="POST" action="/admin/rewards/<%= reward.id %>/delete"><button class="text-xs text-red-400 hover:text-red-300">Remove</button></form>
          </div>
        </div>
      <% }) %>
    </div>

    <form method="POST" action="/admin/campaigns/<%= campaign.id %>/rewards" class="p-4 rounded-lg border border-dashed border-[#2a2a3e]">
      <h4 class="text-sm font-medium mb-3">Add Reward Tier</h4>
      <div class="grid grid-cols-2 gap-2 mb-2">
        <input name="tier_name" placeholder="Tier name" required class="text-sm">
        <input name="referrals_required" type="number" min="1" placeholder="Referrals needed" required class="text-sm">
      </div>
      <input name="description" placeholder="Reward description" class="w-full text-sm mb-2">
      <button class="btn-primary px-4 py-1.5 rounded-lg text-white text-sm">Add Tier</button>
    </form>
  </div>
</div>

<!-- TrueFans CONNECT Embed Codes -->
<div class="card p-6 mt-6">
  <h3 class="text-lg font-semibold mb-2">TrueFans CONNECT Integration</h3>
  <p class="text-xs text-gray-500 mb-4">Add this campaign to your Link-in-Bio, artist page, or show page. Pick the format that fits.</p>

  <div class="space-y-4">
    <!-- Direct Link -->
    <div>
      <label class="block text-sm text-gray-400 mb-1">Direct Campaign Link</label>
      <div class="flex gap-2">
        <input type="text" readonly value="<%= process.env.BASE_URL || 'https://fanloop-backend-production.up.railway.app' %>/c/<%= campaign.slug %>" class="w-full text-sm bg-[#1a1a2e]" id="directLink">
        <button onclick="copyField('directLink')" class="px-3 py-1 bg-purple-600 rounded text-xs text-white whitespace-nowrap">Copy</button>
      </div>
      <span class="text-xs text-gray-600">Use as a button link on your Link-in-Bio or artist page</span>
    </div>

    <!-- Embed Widget (iframe) -->
    <div>
      <label class="block text-sm text-gray-400 mb-1">Embed Widget (iframe)</label>
      <div class="flex gap-2">
        <input type="text" readonly value='<iframe src="<%= process.env.BASE_URL || "https://fanloop-backend-production.up.railway.app" %>/embed/<%= campaign.slug %>" width="100%" height="380" frameborder="0" style="border:none;border-radius:16px;max-width:420px;"></iframe>' class="w-full text-sm bg-[#1a1a2e]" id="embedCode">
        <button onclick="copyField('embedCode')" class="px-3 py-1 bg-purple-600 rounded text-xs text-white whitespace-nowrap">Copy</button>
      </div>
      <span class="text-xs text-gray-600">Paste into any HTML page — CONNECT show pages, artist pages, or custom sites</span>
    </div>

    <!-- Embed Widget URL -->
    <div>
      <label class="block text-sm text-gray-400 mb-1">Embed Widget URL (for Link-in-Bio buttons)</label>
      <div class="flex gap-2">
        <input type="text" readonly value="<%= process.env.BASE_URL || 'https://fanloop-backend-production.up.railway.app' %>/embed/<%= campaign.slug %>" class="w-full text-sm bg-[#1a1a2e]" id="embedUrl">
        <button onclick="copyField('embedUrl')" class="px-3 py-1 bg-purple-600 rounded text-xs text-white whitespace-nowrap">Copy</button>
      </div>
      <span class="text-xs text-gray-600">Use as the URL for a "Join My Campaign" button on your CONNECT Link-in-Bio</span>
    </div>

    <!-- API Endpoint -->
    <div>
      <label class="block text-sm text-gray-400 mb-1">CONNECT API Endpoint</label>
      <div class="flex gap-2">
        <input type="text" readonly value="<%= process.env.BASE_URL || 'https://fanloop-backend-production.up.railway.app' %>/api/connect/campaign/<%= campaign.slug %>" class="w-full text-sm bg-[#1a1a2e]" id="apiUrl">
        <button onclick="copyField('apiUrl')" class="px-3 py-1 bg-purple-600 rounded text-xs text-white whitespace-nowrap">Copy</button>
      </div>
      <span class="text-xs text-gray-600">JSON API — returns campaign data for custom CONNECT integrations</span>
    </div>
  </div>

  <div class="mt-4 p-3 rounded-lg bg-[#1a1a2e] border border-[#2a2a3e]">
    <div class="text-xs text-purple-400 font-semibold mb-1">Where to use these:</div>
    <div class="text-xs text-gray-400 space-y-1">
      <div><strong>Link-in-Bio:</strong> Add the Direct Link as a button, or use the Embed URL for an inline signup form</div>
      <div><strong>Artist Page:</strong> Paste the iframe embed code to show a signup widget on your CONNECT artist page</div>
      <div><strong>Show Pages:</strong> Add a campaign link or embed for each show — fans sign up and refer friends for that specific event</div>
    </div>
  </div>
</div>

<script>
function copyField(id) {
  var input = document.getElementById(id);
  navigator.clipboard.writeText(input.value);
  var btn = input.nextElementSibling;
  btn.textContent = 'Copied!';
  setTimeout(function() { btn.textContent = 'Copy'; }, 1500);
}
</script>

<%- include('../partials/admin-footer') %>
