<%- include('../partials/admin-layout') %>

<div class="mb-8">
  <a href="/admin/artists" class="text-sm text-gray-500 hover:text-gray-300">&larr; Back to Artists</a>
  <h2 class="text-2xl font-bold mt-2"><%= title %></h2>
</div>

<% if (error) { %>
  <div class="bg-red-900/30 border border-red-800 text-red-300 px-4 py-3 rounded-lg mb-6 text-sm"><%= error %></div>
<% } %>

<form method="POST" action="<%= artist && artist.id ? `/admin/artists/${artist.id}` : '/admin/artists' %>" class="max-w-xl">
  <div class="card p-6">
    <div class="space-y-4">
      <div>
        <label class="block text-sm text-gray-400 mb-1">Name *</label>
        <input type="text" name="name" required value="<%= artist?.name || '' %>" class="w-full">
      </div>
      <div>
        <label class="block text-sm text-gray-400 mb-1">Slug *</label>
        <input type="text" name="slug" required value="<%= artist?.slug || '' %>" class="w-full" pattern="[a-z0-9-]+" placeholder="artist-name">
      </div>
      <div>
        <label class="block text-sm text-gray-400 mb-1">Genre</label>
        <input type="text" name="genre" value="<%= artist?.genre || '' %>" class="w-full" placeholder="e.g. Electronic / House">
      </div>
      <div>
        <label class="block text-sm text-gray-400 mb-1">Bio</label>
        <textarea name="bio" rows="3" class="w-full"><%= artist?.bio || '' %></textarea>
      </div>
      <div>
        <label class="block text-sm text-gray-400 mb-1">Image URL</label>
        <input type="url" name="image_url" value="<%= artist?.image_url || '' %>" class="w-full" placeholder="https://...">
      </div>
    </div>
  </div>
  <div class="flex gap-3 mt-6">
    <button type="submit" class="btn-primary px-6 py-2.5 rounded-lg text-white font-semibold">Save Artist</button>
    <a href="/admin/artists" class="px-6 py-2.5 rounded-lg text-gray-400 hover:text-white">Cancel</a>
  </div>
</form>

<%- include('../partials/admin-footer') %>
