<%- include('../partials/admin-layout') %>

<div class="flex items-center justify-between mb-8">
  <div>
    <h2 class="text-2xl font-bold">Fan CRM</h2>
    <p class="text-gray-500 mt-1"><%= total %> total fans</p>
  </div>
  <a href="/admin/fans/export/csv" class="px-4 py-2 rounded-lg text-sm border border-[#2a2a3e] hover:bg-[#1a1a2e]">Export CSV</a>
</div>

<!-- Search -->
<form method="GET" action="/admin/fans" class="mb-6">
  <div class="flex gap-3">
    <input type="text" name="search" value="<%= search || '' %>" placeholder="Search by email or name..." class="flex-1">
    <button class="btn-primary px-5 py-2 rounded-lg text-white text-sm">Search</button>
  </div>
</form>

<!-- Tags -->
<div class="flex items-center gap-2 mb-4 flex-wrap">
  <span class="text-xs text-gray-500">Tags:</span>
  <% tags.forEach(tag => { %>
    <span class="badge" style="background: <%= tag.color %>20; color: <%= tag.color %>"><%= tag.name %></span>
  <% }) %>
  <form method="POST" action="/admin/tags" class="flex gap-1">
    <input name="name" placeholder="New tag" class="text-xs w-24 py-1">
    <input name="color" type="color" value="#6366f1" class="w-6 h-6 cursor-pointer">
    <button class="text-xs text-purple-400">Add</button>
  </form>
</div>

<div class="card overflow-hidden">
  <table>
    <thead>
      <tr class="text-left">
        <th class="px-6 py-3">Fan</th>
        <th class="px-6 py-3">Campaign</th>
        <th class="px-6 py-3"><a href="?sort=referral_count&order=DESC" class="hover:text-purple-400">Referrals</a></th>
        <th class="px-6 py-3">Status</th>
        <th class="px-6 py-3">Source</th>
        <th class="px-6 py-3"><a href="?sort=created_at&order=DESC" class="hover:text-purple-400">Joined</a></th>
      </tr>
    </thead>
    <tbody>
      <% fans.forEach(fan => { %>
        <tr class="hover:bg-[#1a1a2e]">
          <td class="px-6 py-4">
            <a href="/admin/fans/<%= fan.id %>" class="hover:text-purple-400">
              <div class="text-sm font-medium"><%= fan.name || 'No name' %></div>
              <div class="text-xs text-gray-500"><%= fan.email %></div>
            </a>
          </td>
          <td class="px-6 py-4 text-sm text-gray-400"><%= fan.campaign_title || '' %></td>
          <td class="px-6 py-4 font-semibold"><%= fan.referral_count %></td>
          <td class="px-6 py-4">
            <span class="badge <%= fan.status === 'active' ? 'badge-green' : 'badge-red' %>"><%= fan.status %></span>
            <% if (fan.verified) { %><span class="badge badge-blue ml-1">verified</span><% } %>
          </td>
          <td class="px-6 py-4 text-xs text-gray-500"><%= fan.source || 'direct' %></td>
          <td class="px-6 py-4 text-xs text-gray-500"><%= new Date(fan.created_at).toLocaleDateString() %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Pagination -->
<% if (totalPages > 1) { %>
  <div class="flex justify-center gap-2 mt-6">
    <% for (let i = 1; i <= totalPages; i++) { %>
      <a href="?page=<%= i %><%= search ? '&search=' + search : '' %>" class="px-3 py-1 rounded text-sm <%= i === page ? 'bg-purple-600 text-white' : 'bg-[#1a1a2e] text-gray-400 hover:text-white' %>"><%= i %></a>
    <% } %>
  </div>
<% } %>

<%- include('../partials/admin-footer') %>
