<%- include('../partials/admin-layout') %>

<div class="mb-8">
  <h2 class="text-2xl font-bold">Dashboard</h2>
  <p class="text-gray-500 mt-1">Overview of your viral fan campaigns</p>
</div>

<!-- Stat Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <div class="stat-card rounded-xl p-5">
    <div class="text-gray-400 text-sm mb-1">Total Fans</div>
    <div class="text-3xl font-bold text-white"><%= stats.totalFans.toLocaleString() %></div>
  </div>
  <div class="stat-card rounded-xl p-5">
    <div class="text-gray-400 text-sm mb-1">Today's Signups</div>
    <div class="text-3xl font-bold text-green-400"><%= stats.todaySignups %></div>
  </div>
  <div class="stat-card rounded-xl p-5">
    <div class="text-gray-400 text-sm mb-1">K-Factor</div>
    <div class="text-3xl font-bold text-purple-400"><%= stats.kFactor %></div>
  </div>
  <div class="stat-card rounded-xl p-5">
    <div class="text-gray-400 text-sm mb-1">Active Campaigns</div>
    <div class="text-3xl font-bold text-pink-400"><%= stats.activeCampaigns %></div>
  </div>
</div>

<!-- Alert Badges -->
<% if (stats.pendingRewards > 0 || stats.pendingFraud > 0) { %>
<div class="flex gap-3 mb-6">
  <% if (stats.pendingRewards > 0) { %>
    <a href="/admin/rewards" class="badge badge-yellow"><%= stats.pendingRewards %> pending rewards</a>
  <% } %>
  <% if (stats.pendingFraud > 0) { %>
    <a href="/admin/fraud" class="badge badge-red"><%= stats.pendingFraud %> fraud flags</a>
  <% } %>
</div>
<% } %>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Recent Signups -->
  <div class="card p-6">
    <h3 class="text-lg font-semibold mb-4">Recent Signups</h3>
    <div class="space-y-3">
      <% recentSignups.forEach(fan => { %>
        <div class="flex items-center justify-between py-2">
          <div>
            <div class="text-sm font-medium"><%= fan.name || fan.email %></div>
            <div class="text-xs text-gray-500"><%= fan.campaign_title %></div>
          </div>
          <div class="text-xs text-gray-500"><%= new Date(fan.created_at).toLocaleDateString() %></div>
        </div>
      <% }) %>
      <% if (recentSignups.length === 0) { %>
        <p class="text-gray-500 text-sm">No signups yet</p>
      <% } %>
    </div>
  </div>

  <!-- Top Campaigns -->
  <div class="card p-6">
    <h3 class="text-lg font-semibold mb-4">Top Campaigns</h3>
    <div class="space-y-3">
      <% topCampaigns.forEach(campaign => { %>
        <a href="/admin/campaigns/<%= campaign.id %>" class="flex items-center justify-between py-2 hover:bg-[#1a1a2e] rounded px-2 -mx-2">
          <div>
            <div class="text-sm font-medium"><%= campaign.title %></div>
            <span class="badge badge-green"><%= campaign.status %></span>
          </div>
          <div class="text-right">
            <div class="text-sm font-bold"><%= campaign.fan_count %></div>
            <div class="text-xs text-gray-500">fans</div>
          </div>
        </a>
      <% }) %>
      <% if (topCampaigns.length === 0) { %>
        <p class="text-gray-500 text-sm">No active campaigns</p>
      <% } %>
    </div>
  </div>
</div>

<!-- Growth Chart -->
<div class="card p-6 mt-6">
  <h3 class="text-lg font-semibold mb-4">Fan Growth (Last 30 Days)</h3>
  <canvas id="growthChart" height="100"></canvas>
</div>

<script>
  fetch('/api/admin/analytics/growth?days=30')
    .then(r => r.json())
    .then(data => {
      new Chart(document.getElementById('growthChart'), {
        type: 'line',
        data: {
          labels: data.map(d => d.date),
          datasets: [{
            label: 'New Fans',
            data: data.map(d => d.count),
            borderColor: '#8b5cf6',
            backgroundColor: 'rgba(139, 92, 246, 0.1)',
            fill: true,
            tension: 0.4
          }]
        },
        options: {
          responsive: true,
          plugins: { legend: { display: false } },
          scales: {
            x: { ticks: { color: '#64748b' }, grid: { color: '#1e1e2e' } },
            y: { ticks: { color: '#64748b' }, grid: { color: '#1e1e2e' }, beginAtZero: true }
          }
        }
      });
    });
</script>

<%- include('../partials/admin-footer') %>
