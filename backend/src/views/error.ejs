<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/tailwind.min.css">
  <style>body { background: #0a0a0f; color: #e2e8f0; font-family: system-ui, sans-serif; }</style>
</head>
<body class="min-h-screen flex items-center justify-center">
  <div class="text-center">
    <div class="text-6xl font-bold text-gray-700 mb-4"><%= statusCode %></div>
    <h1 class="text-xl font-semibold mb-2"><%= title %></h1>
    <p class="text-gray-500 mb-6"><%= message %></p>
    <a href="/" class="text-purple-400 hover:text-purple-300">Go Home</a>
  </div>
</body>
</html>
